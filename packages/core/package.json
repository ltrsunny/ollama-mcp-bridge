{
  "name": "ollama-mcp-bridge",
  "version": "0.1.1",
  "description": "Universal MCP server that bridges any MCP client (Claude Desktop, Cursor, Cline, Zed, etc.) to a local Ollama instance, so the assistant can delegate lightweight tasks to a local model and save tokens.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/src/lib.js",
  "types": "./dist/src/lib.d.ts",
  "bin": {
    "ollama-mcp": "./dist/bin/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/lib.d.ts",
      "import": "./dist/src/lib.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx bin/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ollama",
    "local-llm",
    "ai-delegation",
    "claude",
    "cursor",
    "cline",
    "zed"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@stackone/defender": "^0.6.2",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "ollama": "^0.6.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
